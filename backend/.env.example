# Backend environment variables
DJANGO_SECRET_KEY=replace-with-a-secure-random-secret
DJANGO_DEBUG=False
DEPLOYMENT_DOMAIN=testiie.indrainstitute.com
DJANGO_ALLOWED_HOSTS=testiie.indrainstitute.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://testiie.indrainstitute.com
CORS_ALLOWED_ORIGINS=https://testiie.indrainstitute.com
APP_PORTAL_URL=https://testiie.indrainstitute.com

# Use either DATABASE_URL or the DB_* values below.
DATABASE_URL=
DB_NAME=iiepulse
DB_USER=iiepulse_user
DB_PASSWORD=replace-with-database-password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_SSL=False
DB_CONN_MAX_AGE=600

DJANGO_MEDIA_ROOT=/var/www/iiepulse/media

BREVO_API_KEY=replace-with-brevo-api-key
DEFAULT_FROM_EMAIL=your-email@example.com
DEFAULT_FROM_NAME=IIE Pulse
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
